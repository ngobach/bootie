# Welcome to Bootie

timeout 60
color red/black
graphicsmode -1 800 || graphicsmode 0x6A

# https://tpedutw-my.sharepoint.com/personal/hikaricalyx_tp_edu_tw/_layouts/15/onedrive.aspx?id=%2Fpersonal%2Fhikaricalyx%5Ftp%5Fedu%5Ftw%2FDocuments%2FHikari%5FPE%5FProject&ga=1
iftitle [if exist /Bootie/Hikari_PE_X64_V9.0_R2_EN.iso] /Bootie/Hikari_PE_X64_V9.0_R2_EN.iso
map /Bootie/Hikari_PE_X64_V9.0_R2_EN.iso (0xff)
map --hook
chainloader (0xff)

iftitle [if exist /Bootie/Hikari_PE_X64_V8.53_R3_EN.iso] /Bootie/Hikari_PE_X64_V8.53_R3_EN.iso
map /Bootie/Hikari_PE_X64_V8.53_R3_EN.iso (0xff)
map --hook
chainloader (0xff)

# https://archive.org/details/windows-7-pesuper-lite-50-mb
iftitle [if exist /Bootie/win7pe.iso] /Bootie/win7pe.iso
map /Bootie/win7pe.iso (0xff)
map --hook
chainloader (0xff)

# https://vn-z.vn/threads/bo-mini-windows-pe-gom-co-winxpe-7xpe-10xpe-tich-hop-vao-2conglc-boot-qua-trung-thu-cho-mem-vnz.27916/
iftitle [if exist /Bootie/xpe.iso] /Bootie/xpe.iso
map /Bootie/xpe.iso (0xff)
map --hook
chainloader (0xff)

# https://github.com/a1ive/grub2-filemanager
iftitle [if exist /Bootie/grubfm.iso] /Bootie/grubfm.iso
map /Bootie/grubfm.iso (0xff)
map --hook
chainloader (0xff)

iftitle [if exist /slax/boot/vmlinuz] Slax
kernel /slax/boot/vmlinuz vga=normal load_ramdisk=1 prompt_ramdisk=0 rw printk.time=0 consoleblank=0 perchdir=resume automount
initrd /slax/boot/initrfs.img
boot

iftitle [if %@UEFI%==64 && find --devices=h /EFI/OC/Opencore.efi] Opencore (EFI)
find --devices=h --set-root /EFI/OC/Opencore.efi
chainloader /EFI/OC/Opencore.efi

iftitle [if %@UEFI%==64 && find --devices=h /EFI/Tools/modGRUBShell.efi] Modified GRUB shell (EFI)
find --devices=h --set-root /EFI/Tools/modGRUBShell.efi
chainloader /EFI/Tools/modGRUBShell.efi

title Reboot
echo Rebooting...
reboot

title Poweroff
echo Powering off...
halt
