# Welcome to Bootie

timeout 60
color red/black
graphicsmode -1 800 || graphicsmode 0x6A

title Hikari PE v9
find --set-root /Bootie/Hikari_PE_X64_V9.0_R2_EN.iso
map /Bootie/Hikari_PE_X64_V9.0_R2_EN.iso (0xff)
map --hook
chainloader (0xff)

title Hikari PE v8
find --set-root /Bootie/Hikari_PE_X64_V8.53_R3_EN.iso
map /Bootie/Hikari_PE_X64_V8.53_R3_EN.iso (0xff)
map --hook
chainloader (0xff)

title Windows 7 PE
find --set-root /Bootie/Windows7PESuperLite50MB.iso
map /Bootie/Windows7PESuperLite50MB.iso (0xff)
map --hook
chainloader (0xff)

title Windows XP PE (LiveXP)
find --set-root /Bootie/LiveXP.iso
map --mem /Bootie/LiveXP.iso (0xff)
map --hook
chainloader (0xff)

title Grub File Manager
find --set-root /Bootie/grubfm.iso
map /Bootie/grubfm.iso (0xff)
map --hook
chainloader (0xff)

title ArchOTG
find --set-root /archotg/vmlinuz-linux
kernel /archotg/vmlinuz-linux root=LABEL=ARCHOTG rw
initrd /archotg/initramfs-linux.img
boot

title Slax
find --set-root /slax/boot/vmlinuz
kernel /slax/boot/vmlinuz vga=normal load_ramdisk=1 prompt_ramdisk=0 rw printk.time=0 consoleblank=0 perchdir=resume automount
initrd /slax/boot/initrfs.img
boot

title Opencore
find --set-root /EFI/OC/Opencore.efi
chainloader /EFI/OC/Opencore.efi

title Modified GRUB shell
find --set-root /EFI/Tools/modGRUBShell.efi
chainloader /EFI/Tools/modGRUBShell.efi

title Reboot
echo Rebooting...
reboot

title Poweroff
echo Powering off...
halt
