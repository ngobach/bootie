# Welcome to Bootie

insmod /autoiso
if not "%@UEFI%"=="" set moddir=/mod/uefi
if "%@UEFI%"=="" set moddir=/mod/bios
insmod %moddir%/file-browser

timeout 60
color red/black
graphicsmode -1 800 || graphicsmode 0x6A
default 2

title Bootie boot menu
pause

title ----
pause

title Browse ISOs (/ISO)
file-browser /ISO/
boot

iftitle [find /grubfm_multiarch.iso] Grub File Manager (/grubfm_multiarch.iso)
find --set-root /grubfm_multiarch.iso
map --mem /grubfm_multiarch.iso (0xff)
map --hook
root (0xff)
chainloader (0xff)
boot

title ----
pause

iftitle [if exist /slax/boot/vmlinuz] Slax
kernel /slax/boot/vmlinuz vga=normal load_ramdisk=1 prompt_ramdisk=0 rw printk.time=0 consoleblank=0 perchdir=resume automount
initrd /slax/boot/initrfs.img
boot

iftitle [if %@UEFI%==64 && find --devices=h /EFI/OC/Opencore.efi] Opencore (EFI)
find --devices=h --set-root /EFI/OC/Opencore.efi
chainloader /EFI/OC/Opencore.efi

iftitle [if %@UEFI%==64 && find --devices=h /EFI/Tools/modGRUBShell.efi] Modified GRUB shell (EFI)
find --devices=h --set-root /EFI/Tools/modGRUBShell.efi
chainloader /EFI/Tools/modGRUBShell.efi

title Reboot
echo Rebooting...
reboot

title Poweroff
echo Powering off...
halt
